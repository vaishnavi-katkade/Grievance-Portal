<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Login - Grievance Portal</title>
  <link rel="stylesheet" href="/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>

<body>
  <div class="login-container">
    <div class="login-box">
      <div class="login-logo">
        <img src="/logo.png" alt="College Logo">
      </div>

      <h1>College Grievance Portal</h1>
      <p class="subtitle">Shreeyash Pratishthan, Chhatrapati Sambhajinagar</p>

      <h2>Admin Login</h2>

      <% if (typeof error !== 'undefined' && error) { %>
      <div style="background: #f8d7da; color: #721c24; border-left: 4px solid #dc3545; padding: 0.8rem 1rem; margin-bottom: 1rem; border-radius: 4px; font-size: 0.9rem; font-weight: 600; text-align: center;">
        <%= error %>
      </div>
      <% } %>

      <form action="/api/auth/admin-login" method="POST">
        <div style="margin-bottom: 1rem;">
          <input type="email" name="email" required placeholder="Admin Email" style="width: 100%;">
        </div>
        <div style="margin-bottom: 1rem;">
          <input type="password" name="password" required autocomplete="current-password" placeholder="Password" style="width: 100%;">
        </div>
        <div style="text-align: center; margin-top: 1.5rem;">
          <button type="submit" style="width: auto; padding: 0.8rem 2.5rem;">LOGIN AS ADMIN</button>
        </div>
      </form>

      <div style="text-align: center; margin-top: 1.5rem; padding-top: 1rem; border-top: 1px solid #eee;">
        <a href="/" style="color: #003366; text-decoration: none; font-size: 0.9rem; font-weight: 600;">
          ← Back to Student Login
        </a>
      </div>
    </div>
  </div>
</body>

</html>
