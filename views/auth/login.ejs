<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Student Login - Grievance Portal</title>
  <link rel="stylesheet" href="/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>

<body>
  <div class="login-container">
    <div class="login-box">
      <div class="login-logo">
        <img src="/logo.png" alt="College Logo">
      </div>

      <h1>College Grievance Portal</h1>
      <p class="subtitle">Shreeyash Pratishthan, Chhatrapati Sambhajinagar</p>

      <h2>Student Login</h2>

      <% if (typeof error !== 'undefined' && error) { %>
      <div style="background: #f8d7da; color: #721c24; border-left: 4px solid #dc3545; padding: 0.8rem 1rem; margin-bottom: 1rem; border-radius: 4px; font-size: 0.9rem; font-weight: 600; text-align: center;">
        <%= error %>
      </div>
      <% } %>
      <% if (typeof success !== 'undefined' && success) { %>
      <div style="background: #d4edda; color: #155724; border-left: 4px solid #28a745; padding: 0.8rem 1rem; margin-bottom: 1rem; border-radius: 4px; font-size: 0.9rem; font-weight: 600; text-align: center;">
        <%= success %>
      </div>
      <% } %>

      <form action="/api/auth/login" method="POST">
      <% if (typeof showOtpField !== 'undefined' && showOtpField) { %>
        <input type="hidden" name="enrollmentNumber" value="<%= enrollmentNumber %>">
        <input type="hidden" name="email" value="<%= email %>">
        <div>
          <p style="font-size: 0.9rem; font-weight: 600; color: #003366; text-align: center; margin-bottom: 0.5rem;">Enter 4-Digit Code</p>
          <input type="text" name="otp" required pattern="\d{4}" maxlength="4" autocomplete="off"
                 style="text-align: center; font-size: 1.8rem; letter-spacing: 0.8em; font-family: monospace; background: #f0f7ff;"
                 placeholder="••••">
        </div>
        <div style="text-align: center; margin-top: 1.5rem;">
          <button type="submit" formaction="/api/auth/verify-otp" style="width: auto; padding: 0.8rem 2.5rem; background: #28a745; border-color: #28a745;">
            VERIFY & ENTER PORTAL
          </button>
        </div>
      <% } else { %>
        <div style="margin-bottom: 1rem;">
          <input type="text" name="enrollmentNumber" required placeholder="Enrollment Number" style="width: 100%;">
        </div>
        <div style="margin-bottom: 1rem;">
          <input type="email" name="email" required placeholder="Registered Email" style="width: 100%;">
        </div>
        <div style="text-align: center; margin-top: 1.5rem;">
          <button type="submit" style="width: auto; padding: 0.8rem 2.5rem;">SEND LOGIN CODE</button>
        </div>
      <% } %>
      </form>

      <div style="text-align: center; margin-top: 1.5rem; padding-top: 1rem; border-top: 1px solid #eee;">
        <a href="/admin-login" style="color: #003366; text-decoration: none; font-size: 0.9rem; font-weight: 600;">
          Admin Login →
        </a>
      </div>
    </div>
  </div>
</body>

</html>
